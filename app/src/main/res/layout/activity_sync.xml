<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?android:colorBackground"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="数据同步"
            app:titleTextColor="?android:textColorPrimary"
            app:titleCentered="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- 状态信息 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="同步状态"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/sync_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="尚未进行过数据同步"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 导出全部数据 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="导出全部数据"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="备份所有数据"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出书签、历史记录、密码、设置等到 JSON 文件，并通过分享功能保存或发送"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_all"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="导出并分享"
                        android:textSize="14sp"
                        app:backgroundTint="@color/md_primary"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 导入数据 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="导入数据"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="恢复数据"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="从之前导出的 JSON 备份文件恢复所有数据"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_import_data"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="选择文件并导入"
                        android:textSize="14sp"
                        app:backgroundTint="@color/md_secondary"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 导出书签 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="导出书签"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出书签"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="仅导出书签到 JSON 文件，保存到本地存储"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_bookmarks"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="导出书签"
                        android:textSize="14sp"
                        app:backgroundTint="@color/md_primary"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 导出密码 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="导出密码"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出密码"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出密码（Base64 编码），请妥善保管。密码将在导出前进行编码处理"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_passwords"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="导出密码"
                        android:textSize="14sp"
                        app:backgroundTint="@color/md_error"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>