<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ====== Top Header (Dark Red) ====== -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/header_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <!-- Tab count -->
        <TextView
            android:id="@+id/tab_count"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/header_text"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/badge_bg"
            android:backgroundTint="#FFFFFF20" />

        <!-- URL Bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/url_bar_container"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/header_search_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/url_lock_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edge_lock"
                    android:tint="#999999"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/url_bar_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@null"
                    android:hint="搜索或输入网址"
                    android:textColorHint="#999999"
                    android:textColor="#1A1C1E"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:fontFamily="sans-serif" />

                <ImageView
                    android:id="@+id/url_share"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edge_share"
                    android:tint="#999999"
                    android:padding="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Menu button -->
        <ImageView
            android:id="@+id/btn_menu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_more_vertical"
            android:tint="@color/header_text"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- ====== Progress Bar ====== -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:progressTint="@color/header_bg"
        android:visibility="gone" />

    <!-- ====== Web Content Area ====== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ====== Find In Page Bar ====== -->
    <include
        android:id="@+id/find_bar"
        layout="@layout/find_in_page_bar"
        android:visibility="gone" />

    <!-- ====== Bottom Navigation Bar ====== -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/bottom_nav_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/bottom_nav_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_forward"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/bottom_nav_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edge_home"
                android:tint="@color/bottom_nav_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_tabs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tabs"
                android:tint="@color/bottom_nav_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_refresh"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/bottom_nav_icon" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>