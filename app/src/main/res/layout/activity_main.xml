<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?android:colorBackground">

        <!-- 顶部工具栏区域 -->
        <LinearLayout
            android:id="@+id/top_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingHorizontal="12dp"
            android:background="?android:colorBackground">

            <!-- 地址栏 (顶部 药丸形状) -->
            <LinearLayout
                android:id="@+id/url_bar_container"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/url_bar_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:elevation="1dp">

                <ImageView
                    android:id="@+id/url_lock_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edge_lock"
                    android:contentDescription="安全"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/url_bar_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:text="搜索或输入网址"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:ellipsize="end"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/btn_share"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_edge_share"
                    android:contentDescription="分享"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_refresh_bar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_refresh"
                    android:contentDescription="刷新"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </LinearLayout>

        <!-- 网页内容区域 -->
        <FrameLayout
            android:id="@+id/content_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_gravity="top"
                android:background="@android:color/transparent"
                android:max="100"
                android:indeterminateOnly="false"
                android:progressTint="@color/md_primary"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 页面内查找栏 -->
        <include
            android:id="@+id/find_bar"
            layout="@layout/find_in_page_bar"
            android:visibility="gone" />

        <!-- 底部导航栏 (Material 3 扁平化) -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bottom_nav_bg"
            android:elevation="8dp"
            android:paddingHorizontal="8dp"
            android:outlineProvider="none">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="后退"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:alpha="0.4" />

            <ImageView
                android:id="@+id/btn_forward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_forward"
                android:contentDescription="前进"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:alpha="0.4" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btn_home"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_edge_home"
                android:contentDescription="主页"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- 标签页按钮 -->
            <FrameLayout
                android:id="@+id/btn_tabs_container"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_tabs"
                    android:contentDescription="标签页" />
                <TextView
                    android:id="@+id/tab_count_text"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/badge_bg"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:visibility="gone" />
            </FrameLayout>

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_more_vertical"
                android:contentDescription="菜单"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>

    <!-- 标签页右侧面板 (卡片式) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tabs_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="?android:colorBackground"
        android:stateListAnimator="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="标签页"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tab_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 个标签页"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tabs_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <TextView
                    android:id="@+id/btn_new_incognito"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="InPrivate 标签页"
                    android:textColor="@color/md_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_close_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="关闭所有"
                    android:textColor="@color/md_error"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.drawerlayout.widget.DrawerLayout>