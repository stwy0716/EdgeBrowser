<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?android:colorBackground"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="设置"
            app:titleTextColor="?android:textColorPrimary"
            app:titleCentered="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- 搜索引擎 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="搜索引擎"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <RadioGroup
                    android:id="@+id/search_engine_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 浏览器内核 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="浏览器内核"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioGroup
                        android:id="@+id/engine_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="12dp"
                        android:text="切换内核后需重启应用生效"
                        android:textColor="@color/md_error"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 外观 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="外观"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <RadioGroup
                    android:id="@+id/theme_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 启动页 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="启动时"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioGroup
                        android:id="@+id/startup_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/homepage_url"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="12dp"
                        android:layout_marginBottom="12dp"
                        android:hint="输入主页网址"
                        android:inputType="textUri"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/url_bar_bg"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 隐私与功能 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="隐私与功能"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 广告拦截 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="广告拦截" android:textColor="?android:textColorPrimary"
                                android:textSize="15sp" android:fontFamily="sans-serif" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="拦截常见广告和追踪器" android:textColor="?android:textColorSecondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/ad_block_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />

                    <!-- 夜间模式 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="夜间模式" android:textColor="?android:textColorPrimary"
                                android:textSize="15sp" android:fontFamily="sans-serif" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="深色背景，保护眼睛" android:textColor="?android:textColorSecondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/night_mode_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />

                    <TextView
                        android:id="@+id/btn_privacy_level"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="跟踪保护：平衡"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />

                    <TextView
                        android:id="@+id/btn_clear_data"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="清除浏览数据"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 数据管理 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="数据管理"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView android:id="@+id/btn_stats" style="@style/SettingsItem" android:text="查看统计" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />
                    <TextView android:id="@+id/btn_passwords" style="@style/SettingsItem" android:text="管理密码" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />
                    <TextView android:id="@+id/btn_reading_list" style="@style/SettingsItem" android:text="管理阅读列表" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />
                    <TextView android:id="@+id/btn_extensions" style="@style/SettingsItem" android:text="管理扩展" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />
                    <TextView android:id="@+id/btn_quick_links" style="@style/SettingsItem" android:text="管理快捷链接" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 关于 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关于"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="版本：3.0.0"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" android:layout_marginHorizontal="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="内核：Gecko 152 + Chromium"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>