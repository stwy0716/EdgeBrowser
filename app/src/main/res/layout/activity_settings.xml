<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/header_bg"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/header_text"
        app:title="设置"
        app:titleTextColor="@color/header_text"
        app:titleCentered="false"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@+id/settings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ====== 常规设置 ====== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/btn_search_engine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="搜索引擎"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:paddingVertical="12dp" />

                    <RadioGroup
                        android:id="@+id/search_engine_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_outline_variant"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/btn_engine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="内核"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:paddingVertical="12dp" />

                    <RadioGroup
                        android:id="@+id/engine_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_outline_variant"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/btn_theme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="主题"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:paddingVertical="12dp" />

                    <RadioGroup
                        android:id="@+id/theme_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_outline_variant"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/btn_startup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="启动页"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:paddingVertical="12dp" />

                    <RadioGroup
                        android:id="@+id/startup_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <EditText
                        android:id="@+id/homepage_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="自定义主页地址"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="14sp"
                        android:padding="12dp"
                        android:background="@android:drawable/edit_text"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ====== 隐私与安全 ====== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/privacy_level"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="隐私与安全"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:paddingVertical="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="广告拦截"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/ad_block_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="仅 HTTPS"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/https_only_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DNS over HTTPS"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/doh_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="不跟踪 (DNT)"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/dnt_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="反指纹"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/anti_fingerprint_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="第三方 Cookie"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/third_party_cookie_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="退出时清除数据"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/clear_on_exit_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_outline_variant"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/btn_cookie_manager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cookie 管理"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_permission_center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="权限中心"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_privacy_level"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="隐私级别"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_clear_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="清除浏览数据"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ====== 功能 ====== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="夜间模式"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/night_mode_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/md_outline_variant"
                        android:layout_marginVertical="4dp" />

                    <TextView
                        android:id="@+id/btn_passwords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="密码管理"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_reading_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="阅读列表"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_extensions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="扩展管理"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_quick_links"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="快速链接"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_backup_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="备份数据"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="统计信息"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/btn_data_sync"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="数据同步"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:paddingVertical="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>