<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?android:colorBackground"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="开发者工具"
        app:titleTextColor="?android:textColorPrimary"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="页面源代码"
                android:textSize="16sp"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="查看页面源代码"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground"
                android:layout_marginBottom="16dp">

                <ScrollView
                    android:id="@+id/source_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_page_source"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?android:textColorPrimary"
                        android:fontFamily="monospace"
                        android:text="点击查看源代码按钮获取页面源码" />
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="控制台输出"
                android:textSize="16sp"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_capture_console"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="注入控制台"
                    android:textSize="14sp"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="4dp"
                    style="@style/Widget.Material3.Button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_console"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="刷新输出"
                    android:textSize="14sp"
                    app:cornerRadius="12dp"
                    android:layout_marginStart="4dp"
                    style="@style/Widget.Material3.Button" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_console"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清除控制台"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?colorSurfaceContainerHighest"
                android:layout_marginBottom="16dp">

                <ScrollView
                    android:id="@+id/console_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_console_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?android:textColorPrimary"
                        android:fontFamily="monospace"
                        android:text="控制台输出将显示在这里" />
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="User Agent 切换"
                android:textSize="16sp"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_current_ua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary"
                android:paddingBottom="8dp"
                android:text="当前UA: 未获取" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Android (默认)"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_desktop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desktop (Windows)"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_macos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desktop (macOS)"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_iphone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="iPhone"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_ipad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="iPad"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ua_custom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自定义UA..."
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.Button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="资源信息"
                android:textSize="16sp"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_resource_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取资源信息"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?android:colorBackground">

                <TextView
                    android:id="@+id/tv_resource_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="?android:textColorPrimary"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text="点击获取资源信息" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>