<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="56dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="极速浏览器"
            android:textColor="?android:textColorPrimary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.02" />

        <!-- 搜索栏 (带渐变边框) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/search_bar_bg"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edge_search"
                    android:contentDescription="搜索" />

                <EditText
                    android:id="@+id/new_tab_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:background="@null"
                    android:hint="搜索或输入网址"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:textSize="15sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorSecondary"
                    android:fontFamily="sans-serif" />

                <ImageView
                    android:id="@+id/btn_voice_search"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_edge_voice"
                    android:contentDescription="语音搜索"
                    android:padding="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </FrameLayout>

        <!-- 快捷站点卡片 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:text="常用站点"
            android:textColor="?android:textColorPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/quick_links_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="20dp"
            android:nestedScrollingEnabled="false" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="24dp"
            android:background="?attr/colorOutline" />

        <!-- 资讯 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:text="我的资讯"
            android:textColor="?android:textColorPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/news_feed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="32dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>