<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="48dp">

        <!-- Logo Area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="极速浏览器"
            android:textColor="?android:textColorPrimary"
            android:textSize="30sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="28dp"
            android:letterSpacing="0.03" />

        <!-- Search Bar (Card with subtle shadow) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="1dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline"
            app:cardBackgroundColor="?android:colorBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edge_search"
                    android:alpha="0.5"
                    android:contentDescription="搜索" />

                <EditText
                    android:id="@+id/new_tab_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:background="@null"
                    android:hint="搜索或输入网址"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:textSize="15sp"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorSecondary"
                    android:fontFamily="sans-serif" />

                <ImageView
                    android:id="@+id/btn_voice_search"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_edge_voice"
                    android:contentDescription="语音搜索"
                    android:padding="2dp"
                    android:alpha="0.5"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Links Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="10dp"
            android:text="常用站点"
            android:textColor="?android:textColorPrimary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/quick_links_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="false" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginHorizontal="24dp"
            android:background="?attr/colorOutline" />

        <!-- News Feed Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp"
            android:text="我的资讯"
            android:textColor="?android:textColorPrimary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/news_feed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="32dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>