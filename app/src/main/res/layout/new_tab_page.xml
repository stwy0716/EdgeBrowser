<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp">

        <!-- Search Bar Container -->
        <FrameLayout
            android:id="@+id/search_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:background="@drawable/search_bar_bg">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_edge_search"
                    android:alpha="0.4"
                    android:contentDescription="搜索" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:background="@null"
                    android:hint="搜索或输入网址"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:fontFamily="sans-serif" />

                <ImageView
                    android:id="@+id/btn_voice_search"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_edge_voice"
                    android:contentDescription="语音搜索"
                    android:padding="2dp"
                    android:alpha="0.4"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </FrameLayout>

        <!-- Quick Links Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/quick_links_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            android:nestedScrollingEnabled="false" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginHorizontal="24dp"
            android:background="#E5E5E5" />

        <!-- News Section -->
        <TextView
            android:id="@+id/news_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:text="新闻资讯"
            android:textColor="#333333"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/news_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="32dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>